rules_version = '2';

// MacroMind – Firestore-Sicherheitsregeln
// Jeder eingeloggte Nutzer darf ausschließlich sein EIGENES
// Dokument unter users/<uid> lesen und schreiben. Kein Zugriff
// auf fremde Daten, kein Zugriff ohne Login.
//
// WICHTIG: Diese Regeln in der Firebase-Console unter
// Firestore Database → Regeln einfügen und veröffentlichen
// (ersetzt die 30-Tage-Testmodus-Regeln).

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Alles andere ist verboten.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
